# Civo API token — get it from https://dashboard.civo.com/security
civo_token = "your-civo-api-token"

# Cluster
region       = "FRA1"  # LON1, NYC1, FRA1, PHX1
cluster_name = "blockchain101-cluster"
node_size    = "g4s.kube.small"  # 1 CPU, 2GB RAM — ~$5/mo (covered by $250 free credit)
node_count   = 1

# Firebase Credentials (use TF_VAR_ env vars instead of committing these)
# export TF_VAR_firebase_project_id="your-project-id"
# export TF_VAR_firebase_private_key_id="your-key-id"
# export TF_VAR_firebase_private_key="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# export TF_VAR_firebase_client_email="firebase-adminsdk@your-project.iam.gserviceaccount.com"
# export TF_VAR_firebase_client_id="123456789"
# export TF_VAR_firebase_client_cert_url="https://www.googleapis.com/robot/v1/metadata/x509/..."
